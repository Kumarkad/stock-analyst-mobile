{
  "expo": {
    "name": "Stock Analyst",
    "slug": "stock-analyst",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kumar.stockanalyst",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0c"
      },
      "package": "com.kumar.stockanalyst"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Stock Analyst AI",
      "shortName": "StockAnalyst",
      "description": "AI-driven equity advisory and prediction engine"
    },
    "extra": {
      "eas": {
        "projectId": "bc27628f-6b34-4fa5-ac1b-e68caa64933c"
      }
    },
    "owner": "mr.tonystark",
    "plugins": [
      "expo-asset"
    ]
  }
}
